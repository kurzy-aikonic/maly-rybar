# Public values for browser-safe usage
PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only values (never expose in client code)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# RevenueCat webhook (Vercel) — v RC nastav stejnou hodnotu do Authorization header (např. "Bearer tajny-token")
REVENUECAT_WEBHOOK_AUTHORIZATION=Bearer tvuj-webhook-tajemstvi
# Identifikátor entitlementu v RevenueCat (default v kódu: premium)
REVENUECAT_ENTITLEMENT_ID=premium
